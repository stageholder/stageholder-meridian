{
  "name": "stageholder-meridian",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:pwa": "turbo run build --filter=pwa",
    "build:desktop": "turbo run build --filter=desktop",
    "build:desktop:production": "turbo run build:production --filter=desktop",
    "dev": "turbo run dev",
    "dev:pwa": "turbo run dev --filter=pwa",
    "dev:desktop": "turbo run dev --filter=pwa --filter=desktop --filter=api",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react-day-picker": "^9.14.0"
  }
}
