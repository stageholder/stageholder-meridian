{
  "name": "stageholder-meridian",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:pwa": "turbo run build --filter=pwa",
    "build:desktop": "turbo run build --filter=desktop",
    "build:desktop:production": "turbo run build:production --filter=desktop",
    "dev": "turbo run dev",
    "dev:pwa": "turbo run dev --filter=pwa --filter=api",
    "dev:desktop": "turbo run dev --filter=pwa --filter=desktop --filter=api",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check": "turbo run check",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@stageholder/sdk": "^1.0.0-alpha.11",
    "react-day-picker": "^9.14.0"
  }
}
