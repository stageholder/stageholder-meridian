{
  "name": "stageholder-meridian",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:pwa": "turbo run build --filter=pwa",
    "build:desktop": "./scripts/build-desktop.sh",
    "build:desktop:production": "turbo run build:production --filter=desktop",
    "publish:desktop": "./scripts/local-publish-desktop.sh",
    "publish:desktop:dry": "./scripts/local-publish-desktop.sh --no-upload",
    "dev": "turbo run dev",
    "dev:pwa": "turbo run dev --filter=pwa --filter=api",
    "dev:desktop": "turbo run dev --filter=desktop --filter=api",
    "mobile": "turbo run dev dev:tunnel --filter=api --filter=@meridian/mobile",
    "mobile:ios": "turbo run dev dev:ios --filter=api --filter=@meridian/mobile",
    "mobile:android": "turbo run dev dev:android --filter=api --filter=@meridian/mobile",
    "tunnel": "bun scripts/toggle-tunnel.ts",
    "tunnel:status": "bun scripts/toggle-tunnel.ts status",
    "tunnel:on": "bun scripts/toggle-tunnel.ts on",
    "tunnel:off": "bun scripts/toggle-tunnel.ts off",
    "tunnel:up": "bun scripts/toggle-tunnel.ts up",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check": "turbo run check",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@stageholder/sdk": "^1.0.0-alpha.47",
    "react-day-picker": "^9.14.0"
  },
  "resolutions": {
    "@tamagui/core": "2.0.0",
    "@tamagui/web": "2.0.0",
    "@tamagui/react-native-web-lite": "2.0.0",
    "tamagui": "2.0.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  },
  "overrides": {
    "tamagui": "2.0.0",
    "@tamagui/core": "2.0.0",
    "@tamagui/web": "2.0.0",
    "@tamagui/config": "2.0.0",
    "@tamagui/animations-css": "2.0.0",
    "@tamagui/lucide-icons-2": "2.0.0",
    "@tamagui/toast": "2.0.0",
    "@tamagui/vite-plugin": "2.0.0",
    "@tamagui/babel-plugin": "2.0.0",
    "@tamagui/react-native-web-lite": "2.0.0",
    "react-native-web": "0.21.2"
  }
}
