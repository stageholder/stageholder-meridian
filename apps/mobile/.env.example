# apps/mobile/.env.example
#
# Copy to `.env.local` and fill in. Every var here is read by the app code
# (grep `EXPO_PUBLIC_` under lib/ and app/). EXPO_PUBLIC_* vars are inlined
# into the JS bundle at build time and are visible in the running app —
# NEVER put secrets here. (OIDC native clients have no client secret; PKCE
# protects the code exchange.)
#
# Host substitution, per platform:
#   - iOS Simulator    → `localhost`
#   - Android emulator → `10.0.2.2` (host loopback)
#   - Real device      → your dev machine's LAN IP, e.g. `192.168.1.42`
#                        (find it with `ipconfig getifaddr en0`)

# ── OIDC issuer URL ─────────────────────────────────────────────────────────
# Must include the `/oidc` path component — Hub mounts oidc-provider there.
# Read by app/_layout.tsx (StageholderProvider config).
# Dev default: Hub API on port 4828.
# Production: https://id.stageholder.com/oidc
EXPO_PUBLIC_STAGEHOLDER_ISSUER_URL=http://localhost:4828/oidc

# ── OIDC client_id ──────────────────────────────────────────────────────────
# Must match a row in Hub's `oidc_clients` table with application_type='native'
# and token_endpoint_auth_method='none'. See README.md for the registration.
# Read by app/_layout.tsx (StageholderProvider config).
EXPO_PUBLIC_STAGEHOLDER_CLIENT_ID=meridian-mobile

# ── Meridian API base URL ───────────────────────────────────────────────────
# Where the app POSTs todos/habits/journal. Read by lib/api/client.ts (raw —
# no auto-suffix), so include the `/api/v1` path convention here. Same host
# substitution rules as the issuer above.
# Dev default: Meridian API on port 4000.
# Production: https://api.meridian.stageholder.com/api/v1
EXPO_PUBLIC_MERIDIAN_API_URL=http://localhost:4000/api/v1

# ── RevenueCat PUBLIC API keys (store IAP) ──────────────────────────────────
# The PUBLIC SDK keys from RevenueCat → Project → API keys → "App specific".
# iOS key starts `appl_…`, Android key starts `goog_…`. These are PUBLIC
# (safe to inline) — their PRESENCE is the feature flag: with a key for the
# running platform, `iapEnabled()` is true and the in-app paywall + store
# management turn on; without it the app stays on the web (Polar) billing
# flow. Read by lib/purchases.ts. Set only the platform(s) you're testing.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx
