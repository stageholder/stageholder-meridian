{
  "expo": {
    "name": "Meridian",
    "slug": "meridian-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "meridian",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.stageholder.meridian.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleURLTypes": [{ "CFBundleURLSchemes": ["meridian"] }],
        "NSFaceIDUsageDescription": "Meridian uses Face ID to keep your sign-in secure on this device."
      }
    },
    "android": {
      "package": "com.stageholder.meridian.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0d1530"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "meridian",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ]
        }
      ]
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
