{
  "expo": {
    "name": "Meridian",
    "slug": "meridian-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "meridian",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.stageholder.meridian.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Meridian uses Face ID to keep your sign-in secure on this device.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stageholder.meridian.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0e7490"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "meridian"
            }
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6a3c2c1-2b5e-436d-8be5-67232d45309f"
      }
    }
  }
}
