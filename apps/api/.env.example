MONGODB_URI=mongodb://localhost:27017/meridian
# PWA dev runs on 4001 to avoid port collision with the Hub web (on 3001).
# In prod this is the deployed PWA origin (no trailing slash). Multiple
# origins can be comma-separated.
FRONTEND_URL=http://localhost:4001
PORT=4000
# Stageholder Hub (OIDC issuer) — API verifies Bearer tokens against this
IDENTITY_ISSUER_URL=http://localhost:4828
IDENTITY_CLIENT_ID=meridian-web
IDENTITY_CLIENT_SECRET=
# aud claim the Hub stamps on access tokens, controlled by the Hub's
# oidc-provider resourceIndicators.defaultResource() config. Keep in
# sync with whatever the Hub issues. Default: "urn:stageholder:api".
IDENTITY_TOKEN_AUDIENCE=urn:stageholder:api
# Server-side encryption key for todos, habits (64 hex chars = 32 bytes)
# Generate with:
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Linux:   openssl rand -hex 32
ENCRYPTION_KEY=
# Fallback timezone for users who have not set one (IANA format, e.g. Asia/Jakarta)
# Defaults to UTC if not set
DEFAULT_TIMEZONE=Asia/Jakarta
