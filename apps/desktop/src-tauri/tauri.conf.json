{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meridian",
  "version": "0.1.0",
  "identifier": "com.stageholder.meridian",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Meridian",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://releases.meridian.stageholder.com/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCNjREREJCQzQ3N0YyRDUKUldUVjhuZkV1OTFrbTcweCs5OWJBR1R0V2JuYkdMWkNkYmQvQytCOEtEb2xHVXNVZ203a0NJSzMK"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
