# Copy to .env.publish (gitignored) and fill in. Sourced by
# scripts/local-publish-desktop.sh — never commit this file.

# Tauri updater signing key (minisign format).
# Generate with: bun --filter=desktop run tauri signer generate -w ~/.tauri/meridian.key -p '<password>'
#
# scripts/local-publish-desktop.sh sources this file with `set -a; source`
# (bash semantics), so `$(...)` expands at load time — `cat ~/.tauri/meridian.key`
# inlines the full multi-line key without you having to paste/escape it.
TAURI_SIGNING_PRIVATE_KEY="$(cat ~/.tauri/meridian.key)"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD='<your-key-password>'

# Cloudflare credentials. The publish script uses `wrangler` (native
# Cloudflare CLI) for R2 uploads — no AWS CLI, no Python, no S3 endpoint
# URL configuration.
#
# Create an API token at:
#   Cloudflare dashboard → My Profile → API Tokens → Create Token
#   Template: "Edit Cloudflare Workers" works, or custom with R2 → Edit
#   permission scoped to the meridian-releases bucket.
CLOUDFLARE_API_TOKEN=
# Find your account ID in the right sidebar of the Cloudflare dashboard
# (under "Account ID").
CLOUDFLARE_ACCOUNT_ID=

# R2 bucket and the custom domain mapped to it. The custom domain MUST
# match `endpoints` in apps/desktop/src-tauri/tauri.conf.json so the
# in-app updater finds latest.json.
R2_BUCKET=meridian-releases
R2_PUBLIC_URL=https://releases.meridian.stageholder.com
