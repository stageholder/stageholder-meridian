# Copy to .env.publish (gitignored) and fill in. Sourced by
# scripts/local-publish-desktop.sh — never commit this file.

# Tauri updater signing key (minisign format).
# Generate with: bun --filter=desktop run tauri signer generate -w ~/.tauri/meridian.key -p <password>
# Then paste the key file's contents here (or use $(cat ~/.tauri/meridian.key)).
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Cloudflare R2 credentials (R2 dashboard → Manage R2 API Tokens).
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Endpoint: https://<your-account-id>.r2.cloudflarestorage.com
# Find <account-id> in the R2 dashboard.
S3_ENDPOINT_URL=

# Bucket name and the custom domain you mapped to it. The custom domain
# MUST match `endpoints` in apps/desktop/src-tauri/tauri.conf.json so the
# updater finds latest.json.
S3_BUCKET=meridian-releases
S3_PUBLIC_URL=https://releases.meridian.stageholder.com

# Optional — R2 ignores region but the AWS CLI needs something.
S3_REGION=auto
